CONFIG_EXPERT=y
CONFIG_EMBEDDED=y

CONFIG_MODULES=n
CONFIG_BLK_DEV_INITRD=n

CONFIG_PERF_EVENTS=n
CONFIG_DEBUG_KERNEL=n
CONFIG_UNWINDER_ORC=n
CONFIG_UNWINDER_NONE=y
CONFIG_MICROCODE=n
CONFIG_SWIOTLB=n
CONFIG_LEGACY_VSYSCALL_XONLY=n

# strip debug/diagnostic (EXPERT-gated)
CONFIG_PRINTK=n
CONFIG_BUG=n
CONFIG_KALLSYMS=n
CONFIG_DEBUG_KERNEL=n

# strip unused syscall surface
CONFIG_AIO=n
CONFIG_IO_URING=n
CONFIG_ADVISE_SYSCALLS=n
CONFIG_MEMBARRIER=n
CONFIG_RSEQ=n
CONFIG_SYSFS_SYSCALL=n
CONFIG_FHANDLE=n

# strip CPU vendors (keep only Intel + AMD)
CONFIG_CPU_SUP_CENTAUR=n
CONFIG_CPU_SUP_ZHAOXIN=n
CONFIG_CPU_SUP_HYGON=n

# strip misc bloat
CONFIG_PERF_EVENTS=n
CONFIG_VDSO_GETRANDOM=n
CONFIG_UNWIND_USER=n
CONFIG_HPET_TIMER=n
CONFIG_X86_MPPARSE=n
CONFIG_DYNAMIC_SIGFRAME=n
CONFIG_HZ_100=y